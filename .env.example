# ============================================
# cat-agent 环境变量配置示例
# 复制此文件为 .env 并根据需要修改
# ============================================
# cp .env.example .env
# ============================================

# ========== 基础配置 ==========

## 应用环境: development | production
# APP_ENV=development

## 服务端口
# SERVER_PORT=8080

## 数据库路径 (SQLite)
# DATABASE_PATH=./data/cat-agent.db

## 数据库引擎: sqlite | postgres
# DB_ENGINE=sqlite

## PostgreSQL DSN (DB_ENGINE=postgres 时使用)
# DB_DSN=postgres://user:password@localhost:5432/cat_agent?sslmode=disable


# ========== 认证安全 ==========

## JWT密钥 (生产环境必须设置)
# JWT_SECRET=your-strong-jwt-secret-key-here

## JWT过期时间 (小时)
# JWT_EXPIRE_HOURS=72


# ========== AI 模型 ==========

## OpenAI / 兼容端点
# OPENAI_BASE=https://api.openai.com/v1
# OPENAI_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# OPENAI_MODEL=gpt-4o-mini

## 本地模型 (Ollama)
# LOCAL_MODEL_URL=http://localhost:11434
# LOCAL_MODEL=qwen2.5


# ========== 速率限制 ==========

## 每分钟最大请求数
# RATE_LIMIT_REQUESTS=100

## 速率限制突发值
# RATE_LIMIT_BURST=20


# ========== HTTP客户端 ==========

## HTTP请求超时 (默认30s)
# HTTP_TIMEOUT=30s

## HTTP最大重试次数
# HTTP_MAX_RETRIES=3

## 重试间隔
# HTTP_RETRY_DELAY=1s

## 最大并发Agent数
# MAX_CONCURRENT_AGENTS=10

## Agent超时时间
# AGENT_TIMEOUT=5m


# ========== 第三阶段: 智能能力增强 ==========

## 记忆嵌入模型: local | openai
# MEMORY_EMBEDDING_MODEL=local

## Cron调度器
# CRON_ENABLED=true

## 沙箱执行
# SANDBOX_ENABLED=false

## WebSocket端口
# WS_PORT=8081


# ========== 第四阶段: 体验优化 ==========

## YAML/TOML配置文件路径 (可选，替代纯环境变量)
# CONFIG_FILE=

## 文档存储目录
# DOCUMENT_DIR=./data/documents

## 导出文件目录
# EXPORT_DIR=./data/exports

## Token告警Webhook
# TOKEN_ALERT_WEBHOOK=
